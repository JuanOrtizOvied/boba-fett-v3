# SABBI is Anthropic-only — the system prompt, tools, and document extraction
# pipeline are built around Claude (claude-sonnet-4-20250514, hardcoded in nodes.py).
ANTHROPIC_API_KEY=

# PostgreSQL connection for portfolio data (products table).
# Portfolio state lives here, not in the LangGraph checkpoint.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabbi

# Optional LangSmith tracing.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=sabbi-portfolio-agent

POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/sabbi-langgraph

JWT_SECRET=S3CR3T
JWT_REFRESH_SECRET=R3FR3$H_S3CR3T
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=admin