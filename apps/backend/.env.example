# LangGraph assistant model configuration.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Provider credentials. Set only the provider key needed for local development.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional LangSmith tracing.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=boba-fett-v3
