# LLM — Claude is the only supported provider.
ANTHROPIC_API_KEY=

# PostgreSQL connection for portfolio data (products table).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabbi

# PostgreSQL connection for LangGraph checkpoint store.
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/sabbi-langgraph

# Auth — JWT signing secrets and initial admin credentials.
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
ADMIN_EMAIL=admin@sabbi.com
ADMIN_PASSWORD=admin

# Web search via Tavily (optional — search tools degrade gracefully without it).
TAVILY_API_KEY=

# LangSmith tracing (optional).
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=sabbi-portfolio-agent

# Integration tests (optional). When unset, integration tests are skipped.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabbi_test
