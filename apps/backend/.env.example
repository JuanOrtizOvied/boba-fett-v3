# SABBI assistant model configuration.
# SABBI is Anthropic-only by design -- the system prompt, tools, and document
# extraction pipeline are built around Claude's capabilities.
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=

# PostgreSQL connection for portfolio data (products table).
# Portfolio state lives here, not in the LangGraph checkpoint.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabbi

# Optional LangSmith tracing.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=sabbi-portfolio-agent
