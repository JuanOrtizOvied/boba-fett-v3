# Browser-visible — LangGraph development endpoint.
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent

# Server-side proxy targets for /api/[...path].
# Routes /portfolio/* and /products/* to PORTFOLIO_API_URL (FastAPI),
# everything else to LANGGRAPH_API_URL (LangGraph agent).
LANGGRAPH_API_URL=http://localhost:2024
LANGCHAIN_API_KEY=
PORTFOLIO_API_URL=http://localhost:3003
