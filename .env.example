# Root development defaults shared by local commands.
# Copy service-specific examples before running the full stack:
#   cp apps/web/.env.example apps/web/.env.local
#   cp apps/backend/.env.example apps/backend/.env

# --- Frontend (browser-visible) ---
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=agent

# --- Frontend (server-side proxy) ---
LANGGRAPH_API_URL=http://localhost:2024
LANGCHAIN_API_KEY=
PORTFOLIO_API_URL=http://localhost:3003

# --- Backend: LLM ---
ANTHROPIC_API_KEY=

# --- Backend: Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabbi
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/sabbi-langgraph

# --- Backend: Auth ---
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
ADMIN_EMAIL=admin@sabbi.com
ADMIN_PASSWORD=admin

# --- Backend: Web search (optional) ---
TAVILY_API_KEY=

# --- Optional: LangSmith tracing ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=sabbi-portfolio-agent

# --- Testing (optional) ---
# When unset, backend integration tests are skipped.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sabbi_test
